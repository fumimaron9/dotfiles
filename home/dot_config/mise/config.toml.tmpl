# https://mise.jdx.dev/registry.html

min_version = '2026.6.11'

[settings]
experimental = true
minimum_release_age = "3d"
pipx.uvx = true
trusted_config_paths = [
  '~/workspace'
]

[settings.cargo]
binstall = true

[tools]
rust = "latest"
cargo-binstall = "latest"
#"cargo:ripgrep" = "latest"
go = "latest"
golangci-lint = "latest"
gofumpt = "latest"
buf = "latest"
"go:github.com/google/osv-scanner/v2/cmd/osv-scanner" = "latest"
"go:github.com/prometheus/alertmanager/cmd/amtool" = "latest"
{{ if ne .chezmoi.os "windows" -}}
"go:github.com/grafana/mcp-grafana/cmd/mcp-grafana" = "latest"
{{ end -}}
java = "latest"
python = "latest"
{{ if ne .chezmoi.os "windows" -}}
"pipx:cisco-ai-skill-scanner" = "latest"
"pipx:snyk-agent-scan" = "latest"
{{ end -}}
uv = "latest"
node = "latest"
pnpm = "latest"
"npm:knip" = "latest"
{{ if ne .chezmoi.os "windows" -}}
"npm:@openai/codex" = "latest"
"npm:@anthropic-ai/claude-code" = "latest"
{{ end -}}
"npm:aws-cdk" = "latest"
aws-sam = "latest"
terraform = "latest"
tflint = "latest"
{{ if ne .chezmoi.os "windows" -}}
trivy = "latest"
{{ end -}}
snyk = "latest"
cloudflared = "latest"
"aqua:grafana/gcx" = "latest"

"aqua:prometheus/prometheus" = "latest"
"aqua:cocogitto/cocogitto" = "latest"
