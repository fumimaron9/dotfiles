model = "gpt-5.4"
model_reasoning_effort = "xhigh"
model_reasoning_summary = "detailed"
#model_context_window = 1000000
#model_auto_compact_token_limit = 900000
personality = "pragmatic"

approval_policy = "untrusted"
sandbox_mode = "read-only"

notify = ["bash", "-lc", "afplay /System/Library/Sounds/Ping.aiff"]
file_opener = "vscode"
hide_agent_reasoning = false
show_raw_agent_reasoning = true

web_search = "cached"

profile = "full_auto"

[sandbox_workspace_write]
network_access = false
writable_roots = []

[shell_environment_policy]


[tui]
show_tooltips = false
status_line = ["model-with-reasoning", "context-remaining", "five-hour-limit", "weekly-limit", "used-tokens", "current-dir", "git-branch"]

[notice]
suppress_unstable_features_warning = true

[features]
unified_exec = true
shell_snapshot = true

steer = true
collaboration_modes = true
multi_agent = true

[mcp_servers]

[mcp_servers.context7]
url = "https://mcp.context7.com/mcp"
http_headers = { "CONTEXT7_API_KEY" = "{{ onepasswordRead "op://Personal/context7 api key/credential" }}" }
enabled = false

[mcp_servers.aws-mcp-server]
command = "uvx"
args = ["mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-west-2"]
startup_timeout_sec = 10
enabled = false

[mcp_servers.eks-mcp-server]
command = "uvx"
args = ["mcp-proxy-for-aws@latest", "https://eks-mcp.us-west-2.api.aws/mcp", "--service", "eks-mcp", "--profile", "f9-practice"]
startup_timeout_sec = 10
enabled = false

[model_providers]


[profiles]

[profiles.full_auto]
approval_policy = "on-request"
sandbox_mode = "workspace-write"

[profiles.readonly_quiet]
approval_policy = "never"
sandbox_mode = "read-only"

[projects]

[projects."{{ .chezmoi.workingTree }}"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/workspace"]
trust_level = "trusted"
