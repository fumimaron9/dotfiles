model = "gpt-5.2-codex"
model_reasoning_effort = "high"
#hide_agent_reasoning = true
hide_agent_reasoning = false
network_access = true

sandbox_mode = "workspace-write"
approval_policy = "untrusted"

file_opener = "vscode"
notify = ["bash", "-lc", "afplay /System/Library/Sounds/Ping.aiff"]

[features]
web_search_request = true
unified_exec = true
shell_snapshot = true
collaboration_modes = true

[mcp_servers.context7]
url = "https://mcp.context7.com/mcp"
http_headers = { "CONTEXT7_API_KEY" = "{{ onepasswordRead "op://Personal/context7 api key/credential" }}" }
enabled = false

[mcp_servers.aws-mcp-server]
command = "uvx"
args = ["mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-west-2"]
startup_timeout_sec = 10
enabled = false

[mcp_servers.eks-mcp-server]
command = "uvx"
args = ["mcp-proxy-for-aws@latest", "https://eks-mcp.us-west-2.api.aws/mcp", "--service", "eks-mcp", "--profile", "f9-practice"]
startup_timeout_sec = 10
enabled = false
