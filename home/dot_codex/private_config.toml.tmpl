model = "gpt-5.2-codex"
model_reasoning_effort = "medium"
hide_agent_reasoning = true
network_access = true

sandbox_mode = "read-only"
approval_policy = "untrusted"

file_opener = "vscode"
notify = ["bash", "-lc", "afplay /System/Library/Sounds/Ping.aiff"]

[features]
web_search_request = true
unified_exec = true
shell_snapshot = true

[mcp_servers.context7]
url = "https://mcp.context7.com/mcp"
http_headers = { "CONTEXT7_API_KEY" = "{{ onepasswordRead "op://Personal/context7 api key/credential" }}" }
enabled = false

[mcp_servers.aws-mcp-server]
command = "uvx"
args = ["mcp-proxy-for-aws@latest", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=us-west-2"]
env = { "AWS_PROFILE" = "f9-practice" }
startup_timeout_sec = 10
enabled = true

[mcp_servers.aws-cdk-mcp-server]
command = "uvx"
args = ["awslabs.cdk-mcp-server@latest"]
startup_timeout_sec = 10
enabled = true

[mcp_servers.eks-mcp-server]
command = "uvx"
args = ["mcp-proxy-for-aws@latest", "https://eks-mcp.us-west-2.api.aws/mcp", "--service", "my-cluster"]
env = { "AWS_PROFILE" = "f9-practice" }
startup_timeout_sec = 10
enabled = false





[notice]
"hide_gpt-5.1-codex-max_migration_prompt" = true

